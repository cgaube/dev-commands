{
  "name": "@devcommands/jira",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "jira": "bun run src/main.ts",
    "build": "bun run ts:check && bun build src/main.ts --outfile dist/jira",
    "compile": "bun run ts:check && bun build src/main.ts --compress --compile --outfile bin/jira",
    "compile:watch": "bun run compile --watch",
    "ts:check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@types/voca": "^1.4.6",
    "colorize-template": "^1.0.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "jira.js": "^5.2.1",
    "picocolors": "^1.1.1",
    "voca": "^1.4.1"
  }
}
