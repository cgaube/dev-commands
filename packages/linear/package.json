{
  "name": "@devcommands/linear",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "linear": "bun run src/main.ts",
    "build": "bun run ts:check && bun build src/main.ts --outfile dist/linear",
    "compile": "bun run ts:check && bun build src/main.ts --compress --compile --outfile bin/linear",
    "compile:watch": "bun run compile --watch",
    "ts:check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@linear/sdk": "^80.0.0",
    "@types/voca": "^1.4.6",
    "colorize-template": "^1.0.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1",
    "voca": "^1.4.1"
  }
}
