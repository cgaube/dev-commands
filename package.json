{
  "name": "commands-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "ts:check": "bun run --workspaces ts:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:check": "eslint --cache --max-warnings 0 .",
    "lint": "bun run lint:check --fix",
    "build": "bun run --workspaces build",
    "compile": "bun run --workspaces compile && bun run cleanup",
    "cleanup": "rm -f packages/*/.*.bun-build",
    "update:dependencies": "bun update -i -r"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
