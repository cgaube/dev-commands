{
  "name": "commands-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "ts:check": "bun run --workspaces ts:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:check": "eslint --cache --max-warnings 0 .",
    "lint": "bun run lint:check --fix",
    "build": "bun run --workspaces build",
    "compile": "bun run --workspaces compile"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/bun": "^1.3.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "@clack/prompts": "^1.0.0-alpha.6",
    "colorize-template": "^1.0.0",
    "commander": "^14.0.1",
    "picocolors": "^1.1.1",
    "execa": "^9.6.0"
  },
  "dependencies": {
    "@types/nconf": "^0.10.7"
  }
}
