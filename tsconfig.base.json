{
  "compilerOptions": {
    // Bun/Node ESM Compatibility
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    // Standard modern TS settings
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "~common/*": ["./common/*"],
      "~src/*": ["${configDir}/src/*"],
    }
  }
}
