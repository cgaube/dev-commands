{
  "name": "@devcommands/git",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "git": "bun run src/main.ts",
    "build": "bun run ts:check && bun build src/main.ts --target bun --outfile dist/git",
    "compile": "bun run ts:check && bun build src/main.ts --compress --compile --outfile bin/git",
    "compile:watch": "bun run compile --watch",
    "ts:check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "colorize-template": "^1.0.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  }
}
